# URL da API principal da plataforma Publica Shopee
API_URL=https://app.publica-shopee.exemplo.com

# JWT de operador com permissão RPA neste workspace
# Gerado pela equipe de TI do seller via /auth/login
API_TOKEN=

# Identificador único do agente (default: hostname da máquina)
AGENT_ID=

# Pasta onde o Playwright salva a sessão do navegador
# (cookies, localStorage). Default: ~/.publica-shopee/browser-profile
USER_DATA_DIR=

# Região Shopee — muda URLs do Seller Centre
# Valores: br, my, id, ph, sg, th, tw, vn
SHOPEE_REGION=br

# Intervalo de polling em ms (mínimo 5000)
POLL_INTERVAL_MS=10000

# Modo headless do Chromium. Recomendado: false (visível para auditoria)
HEADLESS=false

# Raiz de onde o agent lê os arquivos referenciados por videoLocalPath
VIDEOS_ROOT=
